    {
      "id": 14,
      "type": "stat",
      "title": "Threat Intel Flags (1 h)",
      "description": "IPs flagged as malicious by AbuseIPDB in the last hour",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(increase(threat_intel_hits_total[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Error Analysis by Endpoint",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "5xx Server Errors by Endpoint",
      "description": "Critical errors broken down by API path — useful for identifying failing routes",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum by (path) (rate(http_requests_total{status=~\"5..\"}[2m]))",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "4xx Client Errors by Endpoint",
      "description": "Client errors per route — 401/403 = auth issues, 422 = validation, 429 = rate-limited",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
