      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum by (path) (rate(http_requests_total{status=~\"4..\"}[2m]))",
