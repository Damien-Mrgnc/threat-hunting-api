{
  "id": null,
  "uid": "threat-security-v1",
  "title": "Security Dashboard",
  "description": "Authentication failures, rate limiting, ML threat detections, and error analysis",
  "tags": ["security", "threat-hunting", "devsecops"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Authentication & Rate Limiting",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Authentication Failures / min (401)",
      "description": "Rate of HTTP 401 responses — indicates failed JWT validation or brute-force attempts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(http_requests_total{status=\"401\"}[1m]))",
          "legendFormat": "401 Auth failures/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Rate Limit Hits / min (429)",
      "description": "Rate of HTTP 429 responses from SlowAPI — indicates DDoS or aggressive scraping",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(http_requests_total{status=\"429\"}[1m]))",
          "legendFormat": "429 Rate-limited/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Auth Failure Ratio (5 min)",
      "description": "Percentage of requests returning 401 over the last 5 minutes",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(http_requests_total{status=\"401\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "Auth Failure Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Total 401 Errors (1 h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(increase(http_requests_total{status=\"401\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Total Rate-Limited (1 h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(increase(http_requests_total{status=\"429\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Current RPS",
      "description": "Requests per second across all endpoints (1-minute window)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "ML Threat Detection",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Attack Detections / sec (ML)",
      "description": "Rate of network events classified as attacks by the RandomForest model (POST /detect)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Attacks/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Normal/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(ml_detections_total{label=\"1\"}[1m]))",
          "legendFormat": "Attacks/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(rate(ml_detections_total{label=\"0\"}[1m]))",
          "legendFormat": "Normal/s",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "type": "stat",
      "title": "Total Attacks Detected",
      "description": "Cumulative count of events classified as attacks since last restart",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(ml_detections_total{label=\"1\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 13,
      "type": "stat",
      "title": "Total Normal Events Classified",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P1809F7CD0C757562" },
          "expr": "sum(ml_detections_total{label=\"0\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
